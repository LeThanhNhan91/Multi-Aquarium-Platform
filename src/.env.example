# Copy this file to .env and fill in real values
# This file is safe to commit – it contains NO real secrets

# SQL Server connection string
DB_CONNECTION_STRING=

# JWT
JWT_SECRET=change_me_at_least_32_chars_long
JWT_ISSUER=
JWT_AUDIENCE=

# Cloudinary (get from cloudinary.com dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# VnPay
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_BASE_URL=
VNPAY_CALLBACK_URL=
VNPAY_COMMAND=pay
VNPAY_CURR_CODE=VND
VNPAY_VERSION=2.1.0
VNPAY_LOCALE=vn

# URL of the deployed frontend (used for CORS)
FRONTEND_URL=
